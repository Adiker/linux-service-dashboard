<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE policyconfig PUBLIC "-//freedesktop//DTD PolicyKit Policy Configuration 1.0//EN"
    "http://www.freedesktop.org/standards/PolicyKit/1/policyconfig.dtd">
<policyconfig>
    <vendor>Linux Service Dashboard</vendor>
    <vendor_url>https://github.com/Adiker/linux-service-dashboard</vendor_url>

    <action id="io.github.Adiker.LinuxServiceDashboard.smart-helper">
        <description>Read SMART data for disks</description>
        <message>Authentication is required to read SMART data for disks.</message>
        <defaults>
            <allow_any>auth_admin</allow_any>
            <allow_inactive>auth_admin</allow_inactive>
            <allow_active>auth_admin_keep</allow_active>
        </defaults>
        <annotate key="org.freedesktop.policykit.exec.path">@SMART_HELPER_INSTALL_PATH@</annotate>
        <annotate key="org.freedesktop.policykit.exec.allow_gui">false</annotate>
    </action>
</policyconfig>
